      { name: 'Downtown Honolulu', slug: 'honolulu-downtown', lat: 21.3069, lon: -157.8583, description: "Downtown Honolulu's commercial core creates a modest heat island but trade winds keep the urban warming manageable compared to mainland cities." },
      { name: 'Manoa Valley', slug: 'manoa-valley', lat: 21.3090, lon: -157.8066, description: "Manoa Valley is Honolulu's famous rain valley — orographic rainfall from the Ko'olau Mountains makes it significantly wetter and greener than coastal Honolulu." },
      { name: 'Kailua', slug: 'kailua-oahu', lat: 21.4022, lon: -157.7394, description: "Kailua on the windward coast gets more rainfall and stronger trade winds than leeward Honolulu, with a fresher and cloudier daily pattern." },
      { name: 'Hawaii Kai', slug: 'hawaii-kai', lat: 21.2842, lon: -157.7017, description: "Hawaii Kai's marina community at the island's eastern end gets strong channel winds between Oahu and Molokai, making it windier than central Honolulu." },
