      { name: 'Puna District', slug: 'puna-district', lat: 19.5140, lon: -154.9236, description: "The Puna District southeast of Hilo is at the active volcanic rift zone — the 2018 Kilauea eruption destroyed much of Lower Puna and lava flows remain a real hazard." },
      { name: 'Hamakua Coast', slug: 'hamakua-coast', lat: 19.9740, lon: -155.2666, description: "The Hamakua Coast north of Hilo receives even more rainfall than the city and has spectacular waterfalls from the extreme precipitation totals." },
