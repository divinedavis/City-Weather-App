    timezone: 'America/Anchorage',
    description: "Anchorage sits between Cook Inlet and the Chugach Mountains in a unique microclimatic position. The city receives relatively little precipitation compared to other Alaskan cities — about 16 inches annually — because the mountains block Pacific moisture. Winters are cold but the coastal location moderates temperatures compared to interior Alaska.",
    districts: [
      { name: 'Downtown Anchorage', slug: 'anchorage-downtown', lat: 61.2181, lon: -149.9003, description: "Downtown Anchorage on the Knik Arm sees Cook Inlet bore tides and strong williwaw winds that can bring sudden violent gusts off the mountains." },
      { name: 'Midtown', slug: 'anchorage-midtown', lat: 61.1958, lon: -149.8826, description: "Anchorage Midtown's commercial strip is more exposed to prevailing southerly winds from Cook Inlet with minimal wind breaks." },
      { name: 'Hillside', slug: 'anchorage-hillside', lat: 61.1401, lon: -149.7827, description: "Hillside at Chugach foothills sees significantly more snow accumulation and is exposed to mountain-driven weather systems from the east." },
      { name: 'South Anchorage', slug: 'anchorage-south', lat: 61.1137, lon: -149.8601, description: "South Anchorage's forested Chugach-facing terrain receives more orographic precipitation and stays cooler in summer." },
      { name: 'Eagle River', slug: 'eagle-river', lat: 61.3218, lon: -149.5675, description: "Eagle River valley channels cold air drainage off the Chugach Mountains, making it noticeably colder than coastal Anchorage on clear nights." },
      { name: 'Muldoon', slug: 'anchorage-muldoon', lat: 61.2148, lon: -149.7827, description: "Eastern Muldoon sits closer to the Chugach foothills and experiences stronger temperature inversions and heavier snowfall." },
      { name: 'Airport Heights', slug: 'anchorage-airport-heights', lat: 61.2093, lon: -149.8399, description: "Airport Heights near Ted Stevens airport sees dramatic weather windows — clear when downtown is fogged in, or vice versa." },
