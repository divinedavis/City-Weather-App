  {
    name: 'Athens',
    slug: 'athens',
    country: 'Greece',
    flag: '🇬🇷',
    lat: 37.9838,
    lon: 23.7275,
    timezone: 'Europe/Athens',
    description: "Athens has a Mediterranean climate with hot dry summers and mild wet winters. The city sits in the Attica basin surrounded by mountains that trap heat in summer. The Meltemi wind from the Aegean provides some relief on summer afternoons but can make conditions uncomfortable. The Acropolis creates a landmark microclimate.",
    districts: [
      { name: 'Plaka', slug: 'plaka', lat: 37.9726, lon: 23.7280, group: 'Historic', description: "Plaka's historic neighborhood beneath the Acropolis is sheltered by the rock outcrop from northerly winds but sun-baked on south-facing slopes. The marble surfaces of ancient sites reflect and radiate enormous heat in summer." },
      { name: 'Monastiraki', slug: 'monastiraki', lat: 37.9762, lon: 23.7232, group: 'Central', description: "Monastiraki's open square and flea market area receives Meltemi wind channeled between hills. The open exposure makes it one of Athens' breezier central neighborhoods." },
      { name: 'Kolonaki', slug: 'kolonaki', lat: 37.9780, lon: 23.7462, group: 'Northeast', description: "Kolonaki on the slopes of Lycabettus Hill benefits from slight elevation and better ventilation than low-lying Plaka. The hill's presence channels sea breezes differently here." },
      { name: 'Piraeus', slug: 'piraeus', lat: 37.9420, lon: 23.6467, group: 'Port', description: "Piraeus port's Saronic Gulf exposure means constant sea breezes and maritime temperatures — often 3–5°F cooler than central Athens in summer, with stronger Meltemi wind effects." },
      { name: 'Glyfada', slug: 'glyfada', lat: 37.8672, lon: 23.7536, group: 'South Coast', description: "Glyfada's Athenian Riviera position on the Saronic Gulf provides significant sea cooling compared to the city center, making the Athenian Riviera suburbs noticeably more comfortable in summer." },
      { name: 'Kifissia', slug: 'kifissia', lat: 38.0733, lon: 23.8119, group: 'North Suburbs', description: "Kifissia's position in the foothills of Mount Pendeli at 270m elevation makes it the coolest affluent suburb in the Athens basin — historically where wealthy Athenians retreated from summer heat, now 5–8°F cooler than central Athens." },
    ],
  },
