  {
    name: 'Vancouver',
    slug: 'vancouver',
    country: 'Canada',
    flag: '🇨🇦',
    lat: 49.2827,
    lon: -123.1207,
    timezone: 'America/Vancouver',
    description: "Vancouver has one of Canada's mildest climates thanks to its Pacific coast location and mountain barrier to the east. Winters are mild and very rainy; summers are warm and dry — the reverse of most European and east coast cities. The city rarely sees snow or extreme heat.",
    districts: [
      { name: 'Downtown Vancouver', slug: 'downtown-vancouver', lat: 49.2851, lon: -123.1177, group: 'Central', description: "Vancouver's downtown peninsula is surrounded by water on three sides — Burrard Inlet to the north, False Creek to the south, and English Bay to the west — creating moderate temperatures year-round." },
      { name: 'Kitsilano', slug: 'kitsilano', lat: 49.2635, lon: -123.1640, group: 'West', description: "Kitsilano's south-facing beach on English Bay receives the most direct afternoon sun of any Vancouver neighborhood, making it the city's warmest beach area in summer." },
      { name: 'North Vancouver', slug: 'north-vancouver', lat: 49.3253, lon: -123.0688, group: 'North Shore', description: "North Vancouver on the slopes of the North Shore Mountains receives significantly more rainfall than the downtown peninsula — the mountains force Pacific moisture to rise and precipitate. Orographic precipitation is 30-50% higher here." },
      { name: 'Richmond', slug: 'richmond', lat: 49.1666, lon: -123.1336, group: 'South', description: "Richmond sits on a flat delta island at sea level, subject to sea breezes off the Georgia Strait and the moderating influence of the Fraser River. Fog is more common here than in elevated Vancouver." },
      { name: 'East Vancouver', slug: 'east-vancouver', lat: 49.2770, lon: -123.0627, group: 'East', description: "East Van is inland from the waterfront, slightly warmer in summer and more prone to the occasional cold snap that the coastal neighborhoods are shielded from by the Gulf Islands." },
    ],
  },
  {
    name: 'Auckland',
    slug: 'auckland',
    country: 'New Zealand',
    flag: '🇳🇿',
    lat: -36.8509,
    lon: 174.7645,
    timezone: 'Pacific/Auckland',
    description: "Auckland sits on a narrow isthmus between the Tasman Sea and Pacific Ocean with 14 volcanic cones providing elevation within the city. The dual coastlines create very different weather on the western (wilder) vs eastern (calmer) shores. Weather is famously changeable.",
    districts: [
      { name: 'City Centre', slug: 'auckland-city-centre', lat: -36.8406, lon: 174.7400, group: 'Central', description: "Auckland CBD sits on the harbour between the Waitemata and Manukau harbours, exposed to sea breezes from multiple directions. Skyscraper wind tunnels on Queen Street are a constant feature." },
      { name: 'Ponsonby', slug: 'ponsonby', lat: -36.8533, lon: 174.7385, group: 'West', description: "Ponsonby's elevated ridge position west of the CBD catches prevailing westerly winds from the Tasman Sea. Its prominent café strip is frequently wind-exposed but offers excellent views across the Waitemata Harbour." },
      { name: 'Devonport', slug: 'devonport', lat: -36.8297, lon: 174.8006, group: 'North Shore', description: "Devonport's volcanic North Head and Mount Victoria provide wind shelter on their lee sides while the seaward facing slopes receive the full force of harbour swells and winds." },
      { name: 'Mission Bay', slug: 'mission-bay', lat: -36.8620, lon: 174.8239, group: 'East', description: "Mission Bay's east-facing sheltered beach on the Waitemata Harbour is one of Auckland's calmest coastal spots, protected from prevailing westerlies by the city." },
    ],
  },
  {
    name: 'Edinburgh',
    slug: 'edinburgh',
    country: 'United Kingdom',
    flag: '🇬🇧',
    lat: 55.9533,
    lon: -3.1883,
    timezone: 'Europe/London',
    description: "Edinburgh's topography dramatically shapes its weather. The city is built on volcanic hills including Castle Rock and Arthur's Seat. The Firth of Forth to the north and the North Sea to the east mean persistent easterly winds (the 'haar') that roll fog in from the sea, sometimes covering the city for days.",
    districts: [
      { name: 'Old Town', slug: 'edinburgh-old-town', lat: 55.9500, lon: -3.1857, group: 'Central', description: "Edinburgh's medieval Old Town and Royal Mile sit along the ridge between Castle Rock and Holyrood Palace. The castle ramparts create significant wind acceleration, and the narrow closes (alleys) create fierce local turbulence." },
      { name: 'New Town', slug: 'edinburgh-new-town', lat: 55.9556, lon: -3.2021, group: 'North', description: "Edinburgh's Georgian New Town is slightly lower than the Old Town ridge, but its wide streets and exposure to northerly winds from the Firth of Forth make it one of the city's windier districts." },
      { name: 'Leith', slug: 'leith', lat: 55.9756, lon: -3.1723, group: 'North', description: "Leith's port position on the Firth of Forth means direct North Sea exposure. The haar (sea fog) rolling in from the east hits Leith first, sometimes leaving the city centre sunny while the port is blanketed." },
      { name: 'Portobello', slug: 'portobello', lat: 55.9544, lon: -3.1109, group: 'East', description: "Portobello's beach on the Firth of Forth is Edinburgh's coastal escape — directly exposed to haar from the North Sea and strong easterly winds. But on sunny days with westerly winds, it's the city's sunniest spot." },
    ],
  },
  {
    name: 'Zürich',
    slug: 'zurich',
    country: 'Switzerland',
    flag: '🇨🇭',
    lat: 47.3769,
    lon: 8.5417,
    timezone: 'Europe/Zurich',
    description: "Zürich sits at the northern end of Lake Zürich with the Alps to the south and the Jura mountains to the northwest. The lake moderates temperatures significantly — winters are milder and summers cooler than surrounding inland areas. The Föhn (warm southern wind) can raise temperatures dramatically in spring and fall.",
    districts: [
      { name: 'Altstadt', slug: 'zurich-altstadt', lat: 47.3728, lon: 8.5421, group: 'Old City', description: "Zürich's medieval old city along the Limmat River benefits from river cooling in summer while the narrow streets of the Niederdorf provide wind shelter in winter." },
      { name: 'Zürichberg', slug: 'zurichberg', lat: 47.3703, lon: 8.5776, group: 'East', description: "Zürichberg's forested hill east of the center is consistently cooler and more humid than the lakeshore, with the forest creating measurable cooling extending into adjacent residential streets." },
      { name: 'Enge', slug: 'enge', lat: 47.3577, lon: 8.5327, group: 'South', description: "Enge's lakeshore position on the western bank of Lake Zürich provides direct lake breezes and water-cooling effects not available to inland neighborhoods." },
      { name: 'Oerlikon', slug: 'oerlikon', lat: 47.4097, lon: 8.5442, group: 'North', description: "Oerlikon's industrial and commercial character north of the lake means higher heat island intensity than the lakeside residential areas. Its flat terrain and open exposure create significant wind exposure in northerly weather." },
