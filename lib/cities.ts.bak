      { name: 'Scottsdale', slug: 'phoenix-scottsdale', lat: 33.4942, lon: -111.9261, description: "Scottsdale's eastern desert setting is marginally cooler than dense downtown Phoenix but still experiences full desert heat with less urban canopy relief." },
      { name: 'Tempe', slug: 'phoenix-tempe', lat: 33.4255, lon: -111.9400, description: "Tempe near Tempe Town Lake gets some evaporative cooling from the water surface that marginally reduces extreme heat compared to surrounding areas." },
