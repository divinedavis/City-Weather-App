      { name: 'Lahaina', slug: 'lahaina', lat: 20.8783, lon: -156.6825, description: "Lahaina on the dry leeward west coast was historically one of Hawaii's driest settlements — tragically this dryness contributed to the catastrophic 2023 wildfire." },
      { name: 'Kihei', slug: 'kihei', lat: 20.7653, lon: -156.4549, description: "Kihei on Maui's south shore is in the rain shadow of Haleakala and Kaho'olawe — one of the driest, sunniest locations in Hawaii." },
      { name: 'Hana', slug: 'hana', lat: 20.7579, lon: -155.9893, description: "Hana on the east coast is one of Maui's wettest areas, receiving over 80 inches of rain annually from northeasterly trade winds hitting Haleakala's slopes." },
      { name: 'Haiku', slug: 'haiku-maui', lat: 20.9165, lon: -156.2666, description: "Ha'iku on the north slopes is in the rain belt with lush agricultural land and frequent cloud cover contrasting starkly with south Maui." },
      { name: 'Haleakala Summit', slug: 'haleakala-summit', lat: 20.7097, lon: -156.2533, description: "Haleakala summit at 10,023 feet is above the cloud layer and the trade wind inversion — watch the sunrise from above the clouds on this dormant volcano." },
